# src/lib/config.ts constants - not secret, just configurable
# Copy to .env.local and adjust as needed

# CelesTrak TLE source
CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements/gp.php

# Nominatim geocoding
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=Syzygy/1.0 (satellite-transit-finder)

# Engine defaults
DEFAULT_COARSE_INTERVAL_SEC=10
DEFAULT_FINE_INTERVAL_SEC=0.1
DEFAULT_CANDIDATE_THRESHOLD_DEG=2
DEFAULT_RADIUS_KM=100
DEFAULT_DATE_RANGE_DAYS=30
MAX_DATE_RANGE_DAYS=90
MIN_RADIUS_KM=10
MAX_RADIUS_KM=500
GRID_SPACING_KM=2

# TLE cache
TLE_CACHE_TTL_MS=7200000
